#pragma once

enum class FairnessMetric { ENQUEUE_CALL, ENQUEUE_IN, DEQUEUE };

#include <cmath>
double compute_thread_fairness(const std::vector<Record>& records) {
  if (records.empty()) return 1.0;
  std::unordered_map<int, std::pair<double, size_t>> sums;
    for (auto& r : records) {
        if (r.deq_ts > r.in_ts) {
            double wait = r.deq_ts - r.in_ts;
            auto& entry = sums[r.tid];
            entry.first += wait;
            entry.second += 1;
        }
    }
    size_t n = sums.size();
    if (n == 0) return 1.0;
    std::vector<double> avg;
    avg.reserve(n);
    for (auto& kv : sums) {
        avg.push_back(kv.second.first / kv.second.second);
    }
    // Compute mean
    double mean = 0.0;
    for (double v : avg) mean += v;
    mean /= n;
    // Compute variance
    double var = 0.0;
    for (double v : avg) var += (v - mean) * (v - mean);
    var /= n;
    double stddev = std::sqrt(var);
    return 1.0 - (stddev / mean);
}


